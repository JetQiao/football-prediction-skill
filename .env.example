# 可选：本地/自部署 SportteryAPI 地址。未设置时使用官方接口本地降级。
SPORTTERY_API_URL=http://localhost:8787
SPORTTERY_API_KEY=

# 可选增强数据源
API_FOOTBALL_KEY=
THE_ODDS_API_KEY=
FOOTBALL_AUTO_CLUBELO=true

# 仅用于未注册模型的研究降级；生产权重由 OOF 训练产物覆盖
FOOTBALL_MARKET_WEIGHT=0.58
FOOTBALL_OFFICIAL_MARKET_WEIGHT=0.35
FOOTBALL_VALUE_THRESHOLD=0.05
FOOTBALL_MAX_INTEL_LOGIT=0.12
FOOTBALL_REQUEST_TIMEOUT=15
